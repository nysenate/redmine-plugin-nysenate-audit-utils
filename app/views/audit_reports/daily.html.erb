<% html_title(l(:label_audit_daily_report)) -%>

<div class="contextual">
  <%= link_to "Export CSV", daily_project_audit_reports_path(@project, format: :csv, mode: @mode, start_date: params[:start_date], end_date: params[:end_date]), class: "icon icon-download" %>
  <%= link_to "Back to Reports", project_audit_reports_path(@project), class: "icon icon-cancel" %>
</div>

<h2>Daily Report</h2>

<%= form_tag(daily_project_audit_reports_path(@project), method: :get, id: "date-filter-form") do %>
  <fieldset class="box">
    <legend>Query Period</legend>

    <div class="mode-row">
      <span class="mode-row-label">Mode</span>
      <label class="mode-radio">
        <%= radio_button_tag :mode, 'business_day', @mode == 'business_day', class: 'mode-toggle' %>
        <span>Last Business Day</span>
      </label>
      <label class="mode-radio">
        <%= radio_button_tag :mode, 'range', @mode == 'range', class: 'mode-toggle' %>
        <span>Date Range</span>
      </label>
    </div>

    <div id="business-day-block" style="<%= 'display:none;' unless @mode == 'business_day' %>">
      <p>
        <%= label_tag :business_day_date, "Date" %>
        <button type="button" id="prev-day-btn" class="button-small" title="Previous day">&laquo; Prev</button>
        <%= date_field_tag :end_date, @to_date.strftime('%Y-%m-%d'),
            id: 'business_day_date',
            max: 1.day.from_now.to_date.strftime('%Y-%m-%d'),
            class: "date-picker auto-submit",
            disabled: @mode != 'business_day' %>
        <button type="button" id="next-day-btn" class="button-small" title="Next day">Next &raquo;</button>
        <span class="info-text">Covers 12AM of the previous business day to 12AM of the selected date (Monday includes the prior weekend).</span>
      </p>
    </div>

    <div id="range-block" style="<%= 'display:none;' unless @mode == 'range' %>">
      <p>
        <%= label_tag :start_date, "Start Date" %>
        <%= date_field_tag :start_date, @from_date.strftime('%Y-%m-%d'),
            max: 1.day.from_now.to_date.strftime('%Y-%m-%d'),
            class: "date-picker auto-submit",
            disabled: @mode != 'range' %>
        <span class="info-text">Range runs from 12AM of start date to 12AM of end date.</span>
      </p>
      <p>
        <%= label_tag :end_date, "End Date" %>
        <%= date_field_tag :end_date, @to_date.strftime('%Y-%m-%d'),
            id: 'range_end_date',
            max: 1.day.from_now.to_date.strftime('%Y-%m-%d'),
            class: "date-picker auto-submit",
            disabled: @mode != 'range' %>
      </p>
      <p>
        <label></label>
        <button type="button" id="full-week-btn" class="button-small">
          Set to Full Week
        </button>
      </p>
    </div>

    <p>
      <label></label>
      <%= link_to "Reset to Default", daily_project_audit_reports_path(@project), class: "button-small" %>
    </p>
  </fieldset>
<% end %>

<p id="range-too-wide-msg" class="range-warning nodata" style="display:none;">
  Date range exceeds 2 months. Please narrow the range to run the report.
</p>

<div id="report-results">
<% if @report_count.nil? || @report_count.zero? %>
  <p class="nodata">No user status changes found for the query period.</p>
<% else %>
  <p class="report-info">
    Showing <%= pluralize(@report_count, 'user') %> with status changes.
    <br>
    <% if @mode == 'business_day' %>
      Last business day ending <%= @to_date.strftime('%Y-%m-%d') %>
      (query period: <%= @from_date.strftime('%Y-%m-%d') %> to <%= @to_date.strftime('%Y-%m-%d') %>)
    <% else %>
      Date range: <%= @from_date.strftime('%Y-%m-%d') %> to <%= @to_date.strftime('%Y-%m-%d') %>
    <% end %>
  </p>

  <table class="list issues daily-report-table <%= sort_css_classes %>">
    <thead>
      <tr>
        <%= sort_header_tag('user_name', caption: 'Account Holder Name', class: 'holder-col') %>
        <th>Current Status</th>
        <th>Open Tickets</th>
        <%= sort_header_tag('status_changes', caption: 'Status Changes') %>
        <%= sort_header_tag('office', caption: 'Account Holder Office', class: 'holder-col') %>
        <%= sort_header_tag('office_location', caption: 'Account Holder Location', class: 'holder-col') %>
        <%= sort_header_tag('user_id', caption: 'Account Holder ID', class: 'holder-col') %>
        <%= sort_header_tag('user_uid', caption: 'Account Holder Username', class: 'holder-col') %>
        <%= sort_header_tag('post_date', caption: 'Post Date', default_order: 'asc') %>
      </tr>
    </thead>
    <tbody>
      <% @report_data.each do |row| %>
        <tr>
          <td>
            <%
              user_id_field_id = NysenateAuditUtils::CustomFieldConfiguration.user_id_field_id
              filter_url = project_issues_path(@project,
                set_filter: 1,
                "f[]": ["cf_#{user_id_field_id}", "status_id"],
                "op[cf_#{user_id_field_id}]": "=",
                "v[cf_#{user_id_field_id}][]": row[:user_id],
                "op[status_id]": "*"
              )
              # Fix the double array encoding in the URL
              filter_url = filter_url.gsub('f%5B%5D%5B%5D=', 'f%5B%5D=')
            %>
            <%= link_to row[:user_name], filter_url, target: '_blank' %>
          </td>
          <td class="account-status-cell">
            <% if row[:account_statuses].present? %>
              <% can_add = User.current.allowed_to?(:add_issues, @project) %>
              <% row[:account_statuses].each do |status| %>
                <div class="account-status-line">
                  <span class="account-status-name"><%= status[:request_code].presence || "#{status[:account_type]} (no code)" %></span>
                  <% if status[:issue_id].present? %>
                    <%= link_to sprite_icon('issue', l(:label_view_last_ticket), icon_only: true),
                          issue_path(status[:issue_id]),
                          class: 'action-icon',
                          title: l(:label_view_last_ticket), target: '_blank' %>
                  <% end %>
                  <% if can_add && status[:status] == 'active' %>
                    <% if row[:removal_systems].include?(status[:account_type]) %>
                      <%= link_to sprite_icon('del', l(:label_create_removal_ticket), icon_only: true),
                            new_project_account_request_path(@project, employee_id: row[:user_id],
                              target_system: status[:account_type], account_action: 'Delete',
                              from_date: @from_date.iso8601, to_date: @to_date.iso8601),
                            class: 'action-icon create-removal-ticket',
                            title: l(:label_create_removal_ticket), target: '_blank' %>
                    <% else %>
                      <%= content_tag :span,
                            sprite_icon('del', l(:label_removal_ticket_already_open), icon_only: true),
                            class: 'action-icon create-removal-disabled',
                            title: l(:label_removal_ticket_already_open) %>
                    <% end %>
                  <% end %>
                </div>
              <% end %>
            <% else %>
              <span class="no-data">—</span>
            <% end %>
          </td>
          <td class="open-tickets-cell">
            <% row[:open_requests].each do |request| %>
              <div class="open-ticket-line">
                <% if request[:request_code].present? %>
                  <%= link_to request[:request_code], issue_path(request[:issue_id]), target: '_blank' %>
                <% else %>
                  <%= "#{request[:account_type]} (no code)" %>
                <% end %>
              </div>
            <% end %>
            <% if User.current.allowed_to?(:add_issues, @project) %>
              <div class="open-ticket-line create-new-line">
                <%= link_to sprite_icon('add', l(:button_create_new_account_request), icon_only: true),
                      new_project_account_request_path(@project, employee_id: row[:user_id],
                        from_date: @from_date.iso8601, to_date: @to_date.iso8601),
                      class: 'action-icon',
                      title: l(:button_create_new_account_request), target: '_blank' %>
              </div>
            <% elsif row[:open_requests].blank? %>
              <span class="no-data">—</span>
            <% end %>
          </td>
          <td class="status-changes-cell">
            <% if row[:status_changes].present? %>
              <% row[:status_changes].each do |sc| %>
                <div class="status-change-line">
                  <span class="status-change-code"><%= sc[:code] %></span><% if sc[:notes].present? %><span class="status-change-notes"><%= sc[:notes] %></span><% end %>
                </div>
              <% end %>
            <% else %>
              <span class="no-data">—</span>
            <% end %>
          </td>
          <td><%= row[:office] %></td>
          <td><%= row[:office_location] || '—' %></td>
          <td><%= row[:user_id] %></td>
          <td><%= row[:user_uid] %></td>
          <td><%= row[:post_date] %></td>
        </tr>
      <% end %>
    </tbody>
  </table>

  <span class="pagination"><%= pagination_links_full @report_pages, @report_count %></span>
<% end %>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const form = document.getElementById('date-filter-form');
    const fullWeekBtn = document.getElementById('full-week-btn');
    const startDateInput = document.getElementById('start_date');
    const rangeEndDateInput = document.getElementById('range_end_date');
    const businessDayInput = document.getElementById('business_day_date');
    const businessDayBlock = document.getElementById('business-day-block');
    const rangeBlock = document.getElementById('range-block');
    const modeRadios = document.querySelectorAll('.mode-toggle');

    function formatDate(date) {
      const year = date.getFullYear();
      const month = String(date.getMonth() + 1).padStart(2, '0');
      const day = String(date.getDate()).padStart(2, '0');
      return `${year}-${month}-${day}`;
    }

    // Parse a YYYY-MM-DD string as a local date (avoids UTC drift)
    function parseLocal(str) {
      const parts = str.split('-');
      return new Date(parseInt(parts[0], 10), parseInt(parts[1], 10) - 1, parseInt(parts[2], 10));
    }

    // Compute business-day start (date object) for a given selected date
    function businessDayStart(date) {
      const offset = (date.getDay() === 1) ? -3 : -1;
      return new Date(date.getFullYear(), date.getMonth(), date.getDate() + offset);
    }

    function applyMode(mode, opts) {
      opts = opts || {};
      if (mode === 'business_day') {
        // Carry current range end_date into business-day picker if available
        if (opts.carryEndDate && rangeEndDateInput && rangeEndDateInput.value) {
          businessDayInput.value = rangeEndDateInput.value;
        }
        businessDayBlock.style.display = '';
        rangeBlock.style.display = 'none';
        businessDayInput.disabled = false;
        startDateInput.disabled = true;
        rangeEndDateInput.disabled = true;
      } else {
        // Prefill range start with computed business-day start
        if (opts.prefillFromBusinessDay && businessDayInput.value) {
          const selected = parseLocal(businessDayInput.value);
          startDateInput.value = formatDate(businessDayStart(selected));
          rangeEndDateInput.value = businessDayInput.value;
        }
        businessDayBlock.style.display = 'none';
        rangeBlock.style.display = '';
        businessDayInput.disabled = true;
        startDateInput.disabled = false;
        rangeEndDateInput.disabled = false;
      }
    }

    // Mode toggle handler
    modeRadios.forEach(function(radio) {
      radio.addEventListener('change', function() {
        if (!this.checked) return;
        if (this.value === 'business_day') {
          applyMode('business_day', { carryEndDate: true });
        } else {
          applyMode('range', { prefillFromBusinessDay: true });
        }
        form.submit();
      });
    });

    // Validate range mode date span; show warning when > 2 months apart
    const MAX_RANGE_MONTHS = 2;
    const rangeWarning = document.getElementById('range-too-wide-msg');

    function rangeExceedsLimit() {
      if (!startDateInput || !rangeEndDateInput) return false;
      if (!startDateInput.value || !rangeEndDateInput.value) return false;
      const start = parseLocal(startDateInput.value);
      const end = parseLocal(rangeEndDateInput.value);
      const limit = new Date(start.getFullYear(), start.getMonth() + MAX_RANGE_MONTHS, start.getDate());
      return end > limit;
    }

    function isRangeMode() {
      const selected = document.querySelector('.mode-toggle:checked');
      return selected && selected.value === 'range';
    }

    const resultsContainer = document.getElementById('report-results');

    function updateRangeWarning() {
      if (!rangeWarning) return;
      const exceeds = isRangeMode() && rangeExceedsLimit();
      rangeWarning.style.display = exceeds ? '' : 'none';
      if (resultsContainer) resultsContainer.style.display = exceeds ? 'none' : '';
      return exceeds;
    }

    // Auto-submit form when date inputs change (unless range exceeds limit)
    document.querySelectorAll('.auto-submit').forEach(function(input) {
      input.addEventListener('change', function() {
        if (updateRangeWarning()) return;
        form.submit();
      });
    });

    // Block any other submit path (mode toggle, full-week, prev/next) when range too wide
    form.addEventListener('submit', function(e) {
      if (updateRangeWarning()) {
        e.preventDefault();
      }
    });

    // Show warning on initial load if URL params produced a too-wide range
    updateRangeWarning();

    // Set to full week (6 days ago to today) — range mode only
    if (fullWeekBtn) {
      fullWeekBtn.addEventListener('click', function() {
        const now = new Date();
        const sixDaysAgo = new Date(now.getTime() - (6 * 24 * 60 * 60 * 1000));
        startDateInput.value = formatDate(sixDaysAgo);
        rangeEndDateInput.value = formatDate(now);
        form.submit();
      });
    }

    // Prev/Next day buttons — business-day mode only
    const prevDayBtn = document.getElementById('prev-day-btn');
    const nextDayBtn = document.getElementById('next-day-btn');

    function setBtnDisabled(btn, disabled) {
      btn.disabled = disabled;
      btn.style.opacity = disabled ? '0.5' : '1';
      btn.style.cursor = disabled ? 'not-allowed' : 'pointer';
    }

    function updateDayButtonStates() {
      if (!businessDayInput.value) return;
      const current = parseLocal(businessDayInput.value);
      const prev = new Date(current); prev.setDate(prev.getDate() - 1);
      const next = new Date(current); next.setDate(next.getDate() + 1);

      const tomorrow = new Date(); tomorrow.setHours(0,0,0,0); tomorrow.setDate(tomorrow.getDate() + 1);

      setBtnDisabled(prevDayBtn, false);
      setBtnDisabled(nextDayBtn, next.getTime() > tomorrow.getTime());
    }

    if (prevDayBtn && nextDayBtn) {
      prevDayBtn.addEventListener('click', function() {
        if (this.disabled) return;
        const current = parseLocal(businessDayInput.value);
        current.setDate(current.getDate() - 1);
        businessDayInput.value = formatDate(current);
        form.submit();
      });
      nextDayBtn.addEventListener('click', function() {
        if (this.disabled) return;
        const current = parseLocal(businessDayInput.value);
        current.setDate(current.getDate() + 1);
        businessDayInput.value = formatDate(current);
        form.submit();
      });
      businessDayInput.addEventListener('change', updateDayButtonStates);
      updateDayButtonStates();
    }
  });
</script>

<style>
  /* Let "Account Holder X" headers wrap so each column only needs to be wide
     enough for the longest word ("Holder"/"Username"), shrinking overall table
     width. Mirrors the weekly report's vertical-header approach. */
  .daily-report-table thead th {
    white-space: normal;
    vertical-align: bottom;
    line-height: 1.25;
    text-align: center;
    text-indent: 0;
  }

  .daily-report-table thead th a,
  .daily-report-table thead th a.sort,
  .daily-report-table thead th a.icon {
    white-space: normal;
    text-indent: 0;
    text-align: center;
    display: inline;
    padding-right: 0;
    background: none;
  }

  /* On inactive sort headers Redmine emits an empty <svg> before the label; its
     reserved width creates a phantom hanging indent when the header wraps. */
  .daily-report-table thead th a:not(.icon) .icon-svg {
    display: none;
  }
  .daily-report-table thead th a:not(.icon) .icon-label {
    margin-left: 0;
  }

  /* Account-holder columns — wrap headers across 2 lines without overflowing. */
  .daily-report-table thead th.holder-col {
    max-width: 8em;
  }

  /* Current Status / Open Tickets: one entry per line with trailing action icons. */
  table.list.issues td.account-status-cell,
  table.list.issues td.open-tickets-cell {
    white-space: nowrap;
    text-align: left;
    padding-left: 1em;
  }

  .account-status-line,
  .open-ticket-line {
    display: block;
    line-height: 1.6;
    white-space: nowrap;
  }

  .account-status-line .action-icon {
    margin-left: 0.4em;
    vertical-align: middle;
  }

  .open-ticket-line.create-new-line {
    margin-top: 0.3em;
  }

  /* Greyed, non-clickable removal icon for active accounts that already have an
     open removal ticket. */
  .create-removal-disabled {
    cursor: default;
    opacity: 0.4;
  }

  #date-filter-form {
    margin-bottom: 2em;
  }

  #date-filter-form fieldset.box {
    padding: 1em;
  }

  #date-filter-form p {
    display: flex;
    align-items: center;
    gap: 1em;
    margin: 0.5em 0;
  }

  #date-filter-form label {
    min-width: 150px;
    font-weight: bold;
  }

  #date-filter-form .date-picker {
    padding: 0.4em;
    border: 1px solid #ccc;
    border-radius: 3px;
    font-size: 0.95em;
  }

  #date-filter-form .button-small {
    margin-right: 0.5em;
  }

  #date-filter-form #business-day-block p {
    gap: 0.4em;
  }

  #date-filter-form #business-day-block .button-small {
    margin-right: 0;
    padding: 0.3em 0.7em;
    white-space: nowrap;
  }

  #date-filter-form #business-day-block label[for="business_day_date"] {
    margin-right: 0.6em;
  }

  #date-filter-form #business-day-block .info-text {
    margin-left: 0.6em;
  }

  #date-filter-form .mode-row {
    display: flex;
    align-items: center;
    gap: 1em;
    margin: 0.5em 0 1em 0;
  }

  #date-filter-form .mode-row-label {
    min-width: 150px;
    font-weight: bold;
  }

  #date-filter-form .mode-radio {
    display: inline-flex;
    align-items: center;
    gap: 0.4em;
    min-width: 0;
    font-weight: normal;
    cursor: pointer;
  }

  #date-filter-form .mode-radio input[type="radio"] {
    margin: 0;
  }

  #date-filter-form .info-text {
    font-size: 0.9em;
    color: #666;
    font-style: italic;
  }

  .report-info {
    margin-bottom: 1em;
    padding: 0.5em;
    background-color: #f0f0f0;
    border-left: 3px solid #169;
  }

  .pagination {
    display: block;
    margin-top: 1.5em;
  }

  .nodata {
    padding: 2em;
    text-align: center;
    background-color: #f9f9f9;
    border: 1px solid #ddd;
    color: #666;
  }

  .no-data {
    color: #999;
  }

  .range-warning {
    color: #a00;
    font-weight: bold;
    background-color: #fff4f4;
    border: 1px solid #f3c8c8;
    text-align: center;
    padding: 2em;
  }

  .small {
    font-size: 0.85em;
    color: #666;
  }

  /* Multi-line Status Changes column: anchor all cells to the top so rows of
     varying heights stay readable, and allow wrapping inside the cell. */
  table.list.issues td,
  table.list.issues th {
    vertical-align: top;
  }

  table.list.issues td.status-changes-cell {
    white-space: normal;
    word-break: break-word;
    line-height: 1.4;
    text-align: left;
    padding-left: 1em;
  }

  table.list.issues td.status-changes-cell .status-change-line {
    white-space: normal;
    display: flex;
    align-items: flex-start;
  }

  table.list.issues td.status-changes-cell .status-change-code {
    flex: 0 0 3em;
    font-weight: 700;
  }

  table.list.issues td.status-changes-cell .status-change-notes {
    flex: 1 1 auto;
  }

  table.list.issues td.status-changes-cell .status-change-notes {
    font-weight: 400;
    color: #777;
  }
</style>
