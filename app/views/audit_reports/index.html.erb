<% html_title(l(:label_audit_reports)) -%>

<div class="contextual">
</div>

<h2>Audit Reports</h2>

<div class="splitcontentleft">
  <h3>Available Reports</h3>

  <ul>
    <li>
      <%= link_to "Daily Report", daily_project_audit_reports_path(@project) %>
      <p class="small">Shows tickets for employees with status changes in the past 24 hours.</p>
    </li>
    <li>
      <%= link_to "Weekly Report", weekly_project_audit_reports_path(@project) %>
      <p class="small">Lists all tickets active in the current week.</p>
    </li>
    <li>
      <%= link_to "Monthly Report", monthly_project_audit_reports_path(@project) %>
      <p class="small">Snapshot of current employee access status by target system.</p>
    </li>
    <li>
      <%= link_to "SFMS Quarterly / SFS Annual Report", periodic_project_audit_reports_path(@project) %>
      <p class="small">Closed SFMS/SFS tickets for the SFMS Quarterly and SFS Annual audits (CSV).</p>
    </li>
    <li>
      <%= link_to "Account Holder Access Report", account_holder_access_project_audit_reports_path(@project) %>
      <p class="small">Listing of all currently active account access, one row per account.</p>
    </li>
  </ul>
</div>

<div class="splitcontentright">
  <h3>About</h3>
  <p>
    Audit Reports provide security workflow auditing and monitoring based on ticket data
    and employee status changes from the ESS system.
  </p>
</div>

<style>
  .small {
    font-size: 0.9em;
    color: #666;
    margin: 0.2em 0 1em 0;
  }

  .disabled {
    color: #999;
  }
</style>
