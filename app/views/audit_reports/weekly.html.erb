<% html_title(l(:label_audit_weekly_report)) -%>

<div class="contextual">
  <%= link_to "Export CSV", weekly_project_audit_reports_path(@project,
        format: :csv,
        start_date: @from_date.to_date.iso8601,
        end_date: @to_date.to_date.iso8601),
      class: "icon icon-download" %>
  <%= link_to "Back to Reports", project_audit_reports_path(@project), class: "icon icon-cancel" %>
</div>

<h2>Weekly Report</h2>

<%= form_tag(weekly_project_audit_reports_path(@project), method: :get, class: "report-filters") do %>
  <label>
    From:
    <%= date_field_tag :start_date, @from_date.to_date.iso8601 %>
  </label>
  <label>
    To:
    <%= date_field_tag :end_date, @to_date.to_date.iso8601 %>
  </label>
  <%= submit_tag "Apply", name: nil %>
  <% weekly_at_default = params[:start_date].blank? && params[:end_date].blank? %>
  <% if weekly_at_default %>
    <span class="button-small disabled-link">Reset to Default</span>
  <% else %>
    <%= link_to "Reset to Default", weekly_project_audit_reports_path(@project), class: "button-small" %>
  <% end %>
<% end %>

<% if @report_data.nil? || @report_data.empty? %>
  <p class="nodata">No closed tickets found for the selected period.</p>
<% else %>
  <p class="report-info">
    Showing <%= pluralize(@report_data.size, 'closed ticket') %>
    closed between <%= @from_date.to_date.strftime('%Y-%m-%d') %> and <%= @to_date.to_date.strftime('%Y-%m-%d') %>.
  </p>

  <table class="list issues <%= sort_css_classes %>">
    <thead>
      <tr>
        <%= sort_header_tag('issue_id', caption: 'Ticket #') %>
        <%= sort_header_tag('subject', caption: 'Subject') %>
        <%= sort_header_tag('status', caption: 'Status') %>
        <%= sort_header_tag('user_name', caption: 'Account Holder Name') %>
        <%= sort_header_tag('employee_id', caption: 'Account Holder ID') %>
        <%= sort_header_tag('employee_uid', caption: 'Account Holder Username') %>
        <%= sort_header_tag('office', caption: 'Account Holder Office') %>
        <%= sort_header_tag('request_code', caption: 'Request Code') %>
        <%= sort_header_tag('created_on', caption: 'Open Date') %>
        <%= sort_header_tag('closed_on', caption: 'Close Date', default_order: 'desc') %>
        <%= sort_header_tag('updated_on', caption: 'Updated On') %>
      </tr>
    </thead>
    <tbody>
      <% @report_data.each do |row| %>
        <tr>
          <td>
            <%= link_to "##{row[:issue_id]}", issue_path(row[:issue_id]), target: '_blank' %>
          </td>
          <td><%= row[:subject] %></td>
          <td><%= row[:status] %></td>
          <td><%= row[:user_name] || '—' %></td>
          <td><%= row[:user_id] || '—' %></td>
          <td><%= row[:user_uid] || '—' %></td>
          <td><%= row[:office] || '—' %></td>
          <td><%= row[:request_code] || '—' %></td>
          <td><%= row[:created_on]&.strftime('%Y-%m-%d') || '—' %></td>
          <td><%= row[:closed_on]&.strftime('%Y-%m-%d') || '—' %></td>
          <td><%= row[:updated_on]&.strftime('%Y-%m-%d %H:%M') || '—' %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% end %>

<style>
  .report-filters {
    margin-bottom: 1em;
    padding: 0.5em;
    background-color: #f8f8f8;
    border: 1px solid #ddd;
    display: flex;
    align-items: center;
    gap: 1em;
    flex-wrap: wrap;
  }

  .disabled-link {
    opacity: 0.4;
    cursor: default;
    pointer-events: none;
  }

  .report-filters label {
    display: flex;
    align-items: center;
    gap: 0.3em;
  }

  .report-info {
    margin-bottom: 1em;
    padding: 0.5em;
    background-color: #f0f0f0;
    border-left: 3px solid #169;
  }

  .nodata {
    padding: 2em;
    text-align: center;
    background-color: #f9f9f9;
    border: 1px solid #ddd;
    color: #666;
  }
</style>
