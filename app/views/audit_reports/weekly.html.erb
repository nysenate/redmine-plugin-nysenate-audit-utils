<% html_title(l(:label_audit_weekly_report)) -%>

<div class="contextual">
  <%= link_to sprite_icon('download', "Export CSV"), weekly_project_audit_reports_path(@project,
        format: :csv,
        start_date: @from_date.to_date.iso8601,
        end_date: @to_date.to_date.iso8601),
      class: "icon icon-download" %>
  <%= link_to sprite_icon('cancel', "Back to Reports"), project_audit_reports_path(@project), class: "icon icon-cancel" %>
</div>

<h2>Weekly Report</h2>

<%= form_tag(weekly_project_audit_reports_path(@project), method: :get, class: "report-filters") do %>
  <label>
    From:
    <%= date_field_tag :start_date, @from_date.to_date.iso8601, onchange: "this.form.requestSubmit();" %>
  </label>
  <label>
    To:
    <%= date_field_tag :end_date, @to_date.to_date.iso8601, onchange: "this.form.requestSubmit();" %>
  </label>
  <% weekly_at_default = params[:start_date].blank? && params[:end_date].blank? %>
  <% if weekly_at_default %>
    <span class="button-small disabled-link">Reset to Default</span>
  <% else %>
    <%= link_to "Reset to Default", weekly_project_audit_reports_path(@project), class: "button-small" %>
  <% end %>
<% end %>

<% if @report_count.nil? || @report_count.zero? %>
  <p class="nodata">No closed tickets found for the selected period.</p>
<% else %>
  <p class="report-info">
    Showing <%= pluralize(@report_count, 'closed ticket') %>
    closed between <%= @from_date.to_date.strftime('%Y-%m-%d') %> and <%= @to_date.to_date.strftime('%Y-%m-%d') %>.
  </p>

  <div class="weekly-report-table-wrapper">
  <table class="list issues weekly-report-table <%= sort_css_classes %>">
    <thead>
      <tr>
        <%= sort_header_tag('issue_id', caption: 'Ticket #', class: 'ticket-col') %>
        <%= sort_header_tag('subject', caption: 'Subject') %>
        <%= sort_header_tag('status', caption: 'Status') %>
        <%= sort_header_tag('user_type', caption: 'Account Holder Type', class: 'holder-col') %>
        <%= sort_header_tag('user_name', caption: 'Account Holder Name', class: 'holder-col') %>
        <%= sort_header_tag('employee_id', caption: 'Account Holder ID', class: 'holder-col') %>
        <%= sort_header_tag('employee_uid', caption: 'Account Holder Username', class: 'holder-col') %>
        <%= sort_header_tag('office', caption: 'Account Holder Office', class: 'holder-col') %>
        <%= sort_header_tag('request_code', caption: 'Request Code') %>
        <%= sort_header_tag('created_on', caption: 'Open Date', class: 'date-col') %>
        <%= sort_header_tag('closed_on', caption: 'Close Date', default_order: 'desc', class: 'date-col') %>
        <%= sort_header_tag('updated_on', caption: 'Updated On', class: 'date-col') %>
      </tr>
    </thead>
    <tbody>
      <% @report_data.each do |row| %>
        <tr>
          <td class="ticket-col">
            <%= link_to "##{row[:issue_id]}", issue_path(row[:issue_id]), target: '_blank' %>
          </td>
          <td><%= row[:subject] %></td>
          <td><%= row[:status] %></td>
          <td><%= row[:user_type] || '—' %></td>
          <td><%= row[:user_name] || '—' %></td>
          <td><%= row[:user_id] || '—' %></td>
          <td><%= row[:user_uid] || '—' %></td>
          <td><%= row[:office] || '—' %></td>
          <td><%= row[:request_code] || '—' %></td>
          <td class="date-col"><%= row[:created_on]&.strftime('%Y-%m-%d') || '—' %></td>
          <td class="date-col"><%= row[:closed_on]&.strftime('%Y-%m-%d') || '—' %></td>
          <td class="date-col"><%= row[:updated_on]&.strftime('%Y-%m-%d %H:%M') || '—' %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
  </div>

  <span class="pagination"><%= pagination_links_full @report_pages, @report_count %></span>
<% end %>

<style>
  .report-filters {
    margin-bottom: 1em;
    padding: 0.5em;
    background-color: #f8f8f8;
    border: 1px solid #ddd;
    display: flex;
    align-items: center;
    gap: 1em;
    flex-wrap: wrap;
  }

  .disabled-link {
    opacity: 0.4;
    cursor: default;
    pointer-events: none;
  }

  .report-filters label {
    display: flex;
    align-items: center;
    gap: 0.3em;
  }

  .report-info {
    margin-bottom: 1em;
    padding: 0.5em;
    background-color: #f0f0f0;
    border-left: 3px solid #169;
  }

  .pagination {
    display: block;
    margin-top: 1.5em;
  }

  .nodata {
    padding: 2em;
    text-align: center;
    background-color: #f9f9f9;
    border: 1px solid #ddd;
    color: #666;
  }

  .weekly-report-table-wrapper {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    max-width: 100%;
    border: 1px solid #e0e0e0;
  }

  .weekly-report-table {
    min-width: 1100px;
    width: auto;
  }

  .weekly-report-table thead th {
    white-space: normal;
    vertical-align: bottom;
    line-height: 1.25;
    text-align: center;
    text-indent: 0;
  }

  .weekly-report-table thead th a,
  .weekly-report-table thead th a.sort,
  .weekly-report-table thead th a.icon {
    white-space: normal;
    text-indent: 0;
    text-align: center;
    display: inline;
    padding-right: 0;
    background: none;
  }

  .weekly-report-table thead th a .icon-svg {
    display: inline;
    vertical-align: middle;
  }

  /* On inactive sort headers, Redmine still emits an empty <svg> before the
     label. Its reserved width creates a phantom hanging indent when the
     header text wraps. Hide it (and the label's left margin) so wrapped
     lines align cleanly. */
  .weekly-report-table thead th a:not(.icon) .icon-svg {
    display: none;
  }
  .weekly-report-table thead th a:not(.icon) .icon-label {
    margin-left: 0;
  }

  /* Ticket # header link must stay on one line */
  .weekly-report-table thead th.ticket-col,
  .weekly-report-table thead th.ticket-col a,
  .weekly-report-table thead th.ticket-col a.sort {
    white-space: nowrap;
  }

  .weekly-report-table tbody td {
    overflow-wrap: normal;
    word-break: normal;
  }

  /* Keep dates compact and unwrapped */
  .weekly-report-table thead th.date-col,
  .weekly-report-table tbody td.date-col {
    white-space: nowrap;
  }

  /* Ticket # column — keep narrow and unwrapped */
  .weekly-report-table thead th.ticket-col,
  .weekly-report-table tbody td.ticket-col {
    white-space: nowrap;
    width: 1%;
  }

  /* Account-holder columns — wrap headers across 2 lines without overflowing */
  .weekly-report-table thead th.holder-col {
    max-width: 8em;
  }
</style>
