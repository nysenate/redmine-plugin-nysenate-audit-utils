<%= labelled_form_for @tracked_user, url: (@tracked_user.new_record? ? project_tracked_users_path(@project) : project_tracked_user_path(@project, @tracked_user)) do |f| %>
  <%= error_messages_for 'tracked_user' %>

  <div class="box tabular">
    <p>
      <%= f.select :user_type,
          options_for_select([['Vendor', 'Vendor']], @tracked_user.user_type),
          {},
          { required: true, label: 'User Type' } %>
    </p>

    <p>
      <%= f.text_field :user_id, readonly: true, class: 'readonly', required: true, label: 'User ID' %>
      <em class="info">Auto-generated numeric ID (e.g., 500001, 500002)</em>
    </p>

    <p>
      <%= f.text_field :name, size: 60, required: true, maxlength: 200, label: 'Name' %>
    </p>

    <p>
      <%= f.text_field :email, size: 60, maxlength: 200 %>
    </p>

    <p>
      <%= f.text_field :phone, size: 30, maxlength: 50 %>
    </p>

    <p>
      <%= f.text_field :uid, size: 30, maxlength: 100 %>
      <em class="info">Optional system user identifier</em>
    </p>

    <p>
      <%= f.text_field :location, size: 60, maxlength: 200 %>
    </p>

    <p>
      <%= f.select :status,
          options_for_select([['Active', 'Active'], ['Inactive', 'Inactive']], @tracked_user.status),
          {},
          { required: true, label: 'Status' } %>
    </p>
  </div>

  <%= submit_tag(@tracked_user.new_record? ? 'Create User' : 'Save User') %>
  <%= link_to 'Cancel', project_tracked_users_path(@project), class: 'button' %>
<% end %>

<style>
  .readonly {
    background-color: #f5f5f5;
    cursor: not-allowed;
  }

  em.info {
    font-size: 0.9em;
    color: #666;
    font-style: italic;
    margin-left: 0.5em;
  }
</style>
