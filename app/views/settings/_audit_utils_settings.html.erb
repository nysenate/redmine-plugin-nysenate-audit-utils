<%
  # Get overall configuration status
  status = NysenateAuditUtils::ConfigurationStatusService.overall_status
  ess_status = status[:sections][:ess_api]
  custom_fields_status = status[:sections][:custom_fields]
  email_status = status[:sections][:email_reporting]
%>

<!-- Configuration Issues Summary -->
<% if status[:has_issues] %>
  <div class="box config-issues-summary">
    <% if status[:all_errors].any? %>
      <div class="config-needed-notice">
        <div class="config-notice-header">⚠ Configuration Required</div>
        <ul>
          <% status[:all_errors].each do |error| %>
            <li><%= error %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <% if status[:all_warnings].any? %>
      <div class="config-optional-notice">
        <div class="config-notice-header">◆ Optional Configuration</div>
        <ul>
          <% status[:all_warnings].each do |warning| %>
            <li><%= warning %></li>
          <% end %>
        </ul>
      </div>
    <% end %>
  </div>
<% end %>

<!-- Configuration Sections as Accordions -->
<div class="accordion-controls">
  <button type="button" id="expand-all-accordions" class="button-small">Expand All</button>
  <button type="button" id="collapse-all-accordions" class="button-small">Collapse All</button>
</div>

<div class="config-accordions">

  <!-- ESS API Configuration Section -->
  <div class="config-accordion">
    <div class="accordion-header" data-section="ess-api">
      <h3>
        <span class="accordion-toggle">▶</span>
        ESS API Configuration
        <span class="status-badge <%= NysenateAuditUtils::ConfigurationStatusService.status_badge_class(ess_status) %>">
          <%= NysenateAuditUtils::ConfigurationStatusService.status_badge(ess_status) %>
          <%= NysenateAuditUtils::ConfigurationStatusService.status_description(ess_status) %>
        </span>
      </h3>
    </div>

    <div class="accordion-body" id="ess-api-section">
      <div class="box tabular settings">
        <p>
          <%= content_tag 'label', 'ESS Base URL' %>
          <%= text_field_tag 'settings[ess_base_url]', @settings['ess_base_url'],
                             :size => 60, :placeholder => 'https://api.example.com' %>
          <em class="info">Base URL for the Employee Self Service API</em>
        </p>

        <p>
          <%= content_tag 'label', 'ESS API Key' %>
          <%= text_field_tag 'settings[ess_api_key]', @settings['ess_api_key'],
                                 :size => 60, :placeholder => 'API Key' %>
          <em class="info">API key for authentication with ESS</em>
        </p>
      </div>
    </div>
  </div>

  <!-- Custom Field Configuration Section -->
  <div class="config-accordion">
    <div class="accordion-header" data-section="custom-fields">
      <h3>
        <span class="accordion-toggle">▶</span>
        Custom Field Configuration
        <span class="status-badge <%= NysenateAuditUtils::ConfigurationStatusService.status_badge_class(custom_fields_status) %>">
          <%= NysenateAuditUtils::ConfigurationStatusService.status_badge(custom_fields_status) %>
          <%= NysenateAuditUtils::ConfigurationStatusService.status_description(custom_fields_status) %>
          (<%= custom_fields_status[:configured_count] %>/<%= custom_fields_status[:total_count] %>)
        </span>
      </h3>
    </div>

    <div class="accordion-body" id="custom-fields-section">
      <div class="box tabular settings">
        <%
          # Get all field definitions in a single flat list
          field_definitions = NysenateAuditUtils::CustomFieldConfiguration::FIELD_DEFINITIONS

          # Get available custom fields for dropdowns
          custom_field_options = [['-- Select Field --', '']] +
                                CustomField.where(type: 'IssueCustomField').order(:name).pluck(:name, :id)
        %>

        <p style="margin: 1em 0 0.5em 0; padding: 0;">
          Audit Utils requires custom fields to be configured for proper operation. Select fields manually or use auto-configure buttons to automatically detect fields by name.
        </p>

        <%= link_to 'Auto-Configure All Fields',
            autoconfigure_all_audit_utils_settings_path,
            method: :post,
            class: 'button',
            style: 'margin: 0 0 1em 0; display: inline-block;',
            data: { confirm: 'This will automatically detect and configure all custom fields by their expected names. Continue?' } %>

        <table class="list audit-fields-config">
          <thead>
            <tr>
              <th class="field-col">Field</th>
              <th class="select-col">Custom Field</th>
              <th class="auto-col">Auto</th>
              <th class="status-col">Status</th>
            </tr>
          </thead>
          <tbody>
            <% field_definitions.each do |setting_key, definition| %>
              <%
                current_value = @settings[setting_key]
                field_status = NysenateAuditUtils::CustomFieldConfiguration.field_status(setting_key)
                is_configured = field_status[:configured]
              %>
              <tr>
                <td class="field-col">
                  <%= definition[:name] %>
                </td>
                <td class="select-col">
                  <%= select_tag "settings[#{setting_key}]",
                      options_for_select(custom_field_options, current_value),
                      class: 'field-select' %>
                </td>
                <td class="auto-col">
                  <%= link_to 'Auto',
                      autoconfigure_field_audit_utils_settings_path(setting_key: setting_key),
                      method: :post,
                      class: 'button-small',
                      title: "Auto-detect field '#{definition[:name]}'" %>
                </td>
                <td class="status-col">
                  <% if is_configured %>
                    <span class="status-configured" title="<%= field_status[:field_name] %>">
                      ✓ <%= field_status[:field_name] %>
                    </span>
                  <% else %>
                    <span class="status-missing">⚠ Not configured</span>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- Email Reporting Configuration Section -->
  <div class="config-accordion">
    <div class="accordion-header" data-section="email-reporting">
      <h3>
        <span class="accordion-toggle">▶</span>
        Email Reporting Configuration
        <span class="status-badge <%= NysenateAuditUtils::ConfigurationStatusService.status_badge_class(email_status) %>">
          <%= NysenateAuditUtils::ConfigurationStatusService.status_badge(email_status) %>
          <%= NysenateAuditUtils::ConfigurationStatusService.status_description(email_status) %>
        </span>
      </h3>
    </div>

    <div class="accordion-body" id="email-reporting-section">
      <div class="box tabular settings">
        <p style="margin: 1em 0 0.5em 0; padding: 0;">
          Configure default email recipients for scheduled audit reports. Email addresses should be comma-separated.
          Individual rake tasks can override this default by providing a recipients parameter.
        </p>

        <p>
          <%= content_tag 'label', 'Default Report Recipients' %>
          <%= text_field_tag 'settings[report_recipients]', @settings['report_recipients'],
                             :size => 80, :placeholder => 'user1@example.com, user2@example.com' %>
          <em class="info">Default recipients for all automated reports (daily, weekly, monthly)</em>
        </p>

        <div class="flash notice" style="margin-top: 1em;">
          <p><strong>Note:</strong> To enable scheduled reports, you must set up cron jobs on the server. See the plugin README for instructions on configuring rake tasks and cron.</p>
        </div>
      </div>
    </div>
  </div>

</div>

<!-- JavaScript for Accordion Functionality -->
<script>
(function() {
  'use strict';

  // Initialize accordions on page load
  document.addEventListener('DOMContentLoaded', function() {
    initAccordions();
    initToggleAllButton();
  });

  function initAccordions() {
    var headers = document.querySelectorAll('.accordion-header');

    headers.forEach(function(header) {
      var section = header.dataset.section;
      var body = header.nextElementSibling;

      // Restore saved state or default to collapsed
      var isOpen = sessionStorage.getItem('accordion-' + section) === 'open';

      if (isOpen) {
        openAccordion(header, body);
      } else {
        closeAccordion(header, body);
      }

      // Add click handler
      header.addEventListener('click', function() {
        toggleAccordion(header, body, section);
      });
    });
  }

  function initToggleAllButton() {
    var expandButton = document.getElementById('expand-all-accordions');
    var collapseButton = document.getElementById('collapse-all-accordions');

    if (expandButton) {
      expandButton.addEventListener('click', function() {
        expandAllAccordions();
      });
    }

    if (collapseButton) {
      collapseButton.addEventListener('click', function() {
        collapseAllAccordions();
      });
    }
  }

  function expandAllAccordions() {
    var headers = document.querySelectorAll('.accordion-header');

    headers.forEach(function(header) {
      var section = header.dataset.section;
      var body = header.nextElementSibling;

      openAccordion(header, body);
      sessionStorage.setItem('accordion-' + section, 'open');
    });
  }

  function collapseAllAccordions() {
    var headers = document.querySelectorAll('.accordion-header');

    headers.forEach(function(header) {
      var section = header.dataset.section;
      var body = header.nextElementSibling;

      closeAccordion(header, body);
      sessionStorage.setItem('accordion-' + section, 'closed');
    });
  }

  function toggleAccordion(header, body, section) {
    var isOpen = body.style.display !== 'none';

    if (isOpen) {
      closeAccordion(header, body);
      sessionStorage.setItem('accordion-' + section, 'closed');
    } else {
      openAccordion(header, body);
      sessionStorage.setItem('accordion-' + section, 'open');
    }
  }

  function openAccordion(header, body) {
    var toggle = header.querySelector('.accordion-toggle');
    toggle.textContent = '▼';
    body.style.display = 'block';
  }

  function closeAccordion(header, body) {
    var toggle = header.querySelector('.accordion-toggle');
    toggle.textContent = '▶';
    body.style.display = 'none';
  }
})();
</script>

<!-- CSS Styling -->
<style>
/* Configuration Issues Summary */
.config-issues-summary {
  margin-bottom: 2em;
}

.config-needed-notice {
  background-color: #fef5f5;
  border: 1px solid #e8c5c5;
  border-left: 4px solid #c85a54;
  padding: 1em 1.5em;
  border-radius: 4px;
  margin-bottom: 1em;
}

.config-needed-notice .config-notice-header {
  margin: 0 0 0.75em 0;
  color: #a84842;
  font-size: 1.1em;
  font-weight: 600;
}

.config-needed-notice ul {
  margin: 0;
  padding: 0 0 0 1.5em;
}

.config-needed-notice li {
  margin: 0.25em 0;
  color: #555;
  font-size: 1em;
}

.config-optional-notice {
  background-color: #fffef5;
  border: 1px solid #f1e8c5;
  border-left: 4px solid #d4a955;
  padding: 1em 1.5em;
  border-radius: 4px;
  margin-bottom: 1em;
}

.config-optional-notice .config-notice-header {
  margin: 0 0 0.75em 0;
  color: #8b7433;
  font-size: 1.1em;
  font-weight: 600;
}

.config-optional-notice ul {
  margin: 0;
  padding: 0 0 0 1.5em;
}

.config-optional-notice li {
  margin: 0.25em 0;
  color: #555;
  font-size: 1em;
}

/* Accordion Controls */
.accordion-controls {
  margin: 1em 0 0.5em 0;
  text-align: left;
}

.accordion-controls .button-small {
  margin-right: 0.5em;
}

/* Accordion Styles */
.config-accordions {
  margin-top: 0.5em;
}

.config-accordion {
  margin-bottom: 1em;
  border: 1px solid #ddd;
  border-radius: 4px;
  overflow: hidden;
}

.accordion-header {
  background: linear-gradient(to bottom, #f8f8f8 0%, #ececec 100%);
  cursor: pointer;
  padding: 0.5em 1em;
  border-bottom: 1px solid #ddd;
  user-select: none;
}

.accordion-header:hover {
  background: linear-gradient(to bottom, #f0f0f0 0%, #e0e0e0 100%);
}

.accordion-header h3 {
  margin: 0;
  padding: 0;
  font-size: 1.1em;
  display: flex;
  align-items: center;
  gap: 0.5em;
}

.accordion-toggle {
  display: inline-block;
  width: 1em;
  font-size: 0.8em;
  transition: transform 0.2s;
}

.status-badge {
  margin-left: 0.5em;
  padding: 0.25em 0.75em;
  border-radius: 3px;
  font-size: 0.85em;
  font-weight: 600;
  white-space: nowrap;
}

.status-badge.status-ok {
  background-color: #d4edda;
  color: #155724;
  border: 1px solid #c3e6cb;
}

.status-badge.status-warning {
  background-color: #fff3cd;
  color: #856404;
  border: 1px solid #ffeaa7;
}

.status-badge.status-error {
  background-color: #f8d7da;
  color: #721c24;
  border: 1px solid #f5c6cb;
}

.accordion-body {
  display: none;
  padding: 1em;
  background-color: #fff;
}

.accordion-body .box {
  margin: 0;
  border: none;
  padding: 0;
}

/* Custom Field Configuration Table */
.button-small {
  padding: 4px 10px;
  font-size: 0.85em;
  white-space: nowrap;
}

.required {
